# Cloudinary (free tier, no login needed for uploads once configured)
# Sign up free at https://cloudinary.com -> Dashboard gives you these:
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Create an UNSIGNED upload preset in Cloudinary settings -> Upload -> Add upload preset
CLOUDINARY_UPLOAD_PRESET=do_as_i_say_unsigned

# Groq (free tier) - get key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key
